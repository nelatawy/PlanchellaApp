<?xml version="1.0" encoding="UTF-8" ?>

<hibernate-configuration xmlns="http://www.hibernate.org/xsd/orm/cfg">
    <session-factory>
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/planchella</property>
        <property name="hibernate.connection.username">postgres</property>
        <property name="hibernate.connection.password">postgres</property>

        <property name="hibernate.hbm2ddl.auto">create</property>

        <mapping class="com.planchella.entities.EventEntity"/>
        <mapping class="com.planchella.entities.UserEntity"/>
        <mapping class="com.planchella.entities.CommunityEntity"/>
        <mapping class="com.planchella.entities.MembershipEntity"/>
        <mapping class="com.planchella.domain.AttachmentMetadata"/>

    </session-factory>
</hibernate-configuration>